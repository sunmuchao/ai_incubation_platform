# 服务配置
SERVICE_NAME=human-ai-community
ENVIRONMENT=development
DEBUG=true
PORT=8007

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=human_ai_community
DB_ECHO=false

# 统一账号体系配置
UNIFIED_AUTH_URL=http://account.example.com/api
UNIFIED_AUTH_APP_ID=community-app
UNIFIED_AUTH_APP_SECRET=your-secret-key

# JWT 配置
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# Redis 配置（可选，用于缓存和速率限制）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
