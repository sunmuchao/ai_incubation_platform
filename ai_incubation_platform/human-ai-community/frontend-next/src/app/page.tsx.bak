/**
 * Next.js 首页组件
 */
'use client';

import { AppLayout } from '@/components/layout/AppLayout';
import { useEffect } from 'react';
import { useAppStore, appActions } from '@/stores/useAppStore';

export default function Home() {
  const currentTab = useAppStore((state) => state.currentTab);

  // 初始加载数据
  useEffect(() => {
    // 根据当前标签页加载对应数据
    const loadInitialData = async () => {
      switch (currentTab) {
        case 'home':
          await appActions.loadFeed('hot');
          break;
        case 'channels':
          await appActions.loadChannels();
          break;
        case 'notifications':
          await appActions.loadNotifications();
          break;
      }
    };

    loadInitialData();
  }, [currentTab]);

  return <AppLayout />;
}
