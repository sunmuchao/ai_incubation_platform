# 红娘 Agent 配置文件模板
# 复制此文件为 .env 并修改配置值

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
DEBUG=false
ENVIRONMENT=development

# JWT 配置（生产环境必须修改为强密钥）
JWT_SECRET_KEY=your-strong-secret-key-here-32-characters-minimum
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/matchmaker
# 开发环境可以使用 SQLite: sqlite:///./matchmaker_agent.db

# 数据库连接池配置（生产环境优化）
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Redis 配置（可选，用于缓存和会话）
REDIS_URL=redis://localhost:6379/0

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS 配置
# 生产环境必须显式配置可信域名列表（逗号分隔），且禁止包含 "*"
# 例如：CORS_ALLOWED_ORIGINS=https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# LLM 配置（可选，用于话术增强）
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo

# 孵化器门户集成（可选）
PORTAL_ENABLED=false
PORTAL_API_URL=
PORTAL_API_KEY=
