# 服务配置
HOST=0.0.0.0
PORT=8009
ENVIRONMENT=development
DEBUG=false

# API 安全配置
SECURITY__API_KEY=your-secret-api-key-here
SECURITY__DEFAULT_ROLE=read_only
SECURITY__MAX_QUERY_ROWS=10000
SECURITY__QUERY_TIMEOUT=30

# 限流配置
RATE_LIMIT__ENABLED=true
RATE_LIMIT__MAX_REQUESTS_PER_MINUTE=60
RATE_LIMIT__MAX_CONCURRENT_QUERIES=10
RATE_LIMIT__BURST_LIMIT=20

# 审计配置
AUDIT__ENABLED=true
AUDIT__LOG_ALL_QUERIES=true
AUDIT__LOG_SENSITIVE_DATA=false
AUDIT__RETENTION_DAYS=90

# 连接器配置
CONNECTOR__DEFAULT_MAX_CONNECTIONS=10
CONNECTOR__CONNECTION_TIMEOUT=10
CONNECTOR__IDLE_TIMEOUT=300

# 凭据管理配置
CREDENTIAL__USE_ENV_CREDENTIALS=true
CREDENTIAL__ENV_PREFIX=DATASOURCE_

# 数据源凭据示例（从环境变量读取，避免硬编码）
# 方式 A：直接提供完整连接串（推荐）
# DATASOURCE_MY_PROD_CONNECTION_STRING=mysql://username:secure-password@mysql-host:3306/mydb

# 方式 B：提供连接所需字段（connection_manager 会按 connector_type 拼装 DSN）
# DATASOURCE_MY_PROD_HOST=mysql-host
# DATASOURCE_MY_PROD_PORT=3306
# DATASOURCE_MY_PROD_USER=username
# DATASOURCE_MY_PROD_PASSWORD=secure-password
# DATASOURCE_MY_PROD_DATABASE=mydb

# AI 功能配置（NL2SQL AI 驱动）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI 功能开关
AI__NL2SQL_USE_LLM=true
AI__ENABLE_INTENT_RECOGNITION=true
AI__ENABLE_RESULT_EXPLANATION=true
AI__ENABLE_QUERY_OPTIMIZATION=true
AI__SCHEMA_AUTO_EVOLUTION=true
AI__SCHEMA_AUTO_APPLY=false

# 血缘持久化配置
LINEAGE__ENABLED=true
LINEAGE__DB_TYPE=sqlite
LINEAGE__DB_PATH=./data/lineage.db
LINEAGE__RETENTION_DAYS=90

# 监控告警配置
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
