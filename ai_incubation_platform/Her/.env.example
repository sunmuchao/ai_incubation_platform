# 红娘 Agent 配置文件模板
# 复制此文件为 .env 并修改配置值

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
DEBUG=false
ENVIRONMENT=development

# JWT 配置（生产环境必须修改为强密钥）
JWT_SECRET_KEY=your-strong-secret-key-here-32-characters-minimum
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# 数据库配置
# 生产环境推荐使用 PostgreSQL，开发环境可使用 SQLite
# PostgreSQL: postgresql://user:password@host:port/database
# SQLite: sqlite:///./matchmaker_agent.db
DATABASE_URL=postgresql://user:password@localhost:5432/matchmaker
# 开发环境取消下方注释使用 SQLite:
# DATABASE_URL=sqlite:///./matchmaker_agent.db

# 数据库连接池配置（生产环境优化）
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Redis 配置（缓存和会话管理，生产环境推荐配置）
# Redis: redis://host:port/db
REDIS_URL=redis://localhost:6379/0
# 生产环境取消下方注释启用 Redis:
# REDIS_URL=redis://your-redis-host:6379/0

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=text                       # text 或 json

# 日志备份配置（系统重启时自动备份）
LOG_CLEANER_ENABLED=true              # 是否启用日志备份（true/false）
LOG_CLEANER_MAX_AGE_DAYS=7            # 日志文件最大保留天数（仅用于清理，不影响备份）
LOG_CLEANER_MAX_SIZE_MB=50            # 单个日志文件最大大小 MB（超过会告警）
LOG_CLEANER_MAX_FILES=20              # 日志目录最大文件数（仅用于清理，不影响备份）
LOG_BACKUP_KEEP_COUNT=10              # 保留最近 N 次重启的日志备份

# 测试配置
# 运行测试：pytest tests/ -v
# 测试数据库：sqlite:///./test_matchmaker.db（自动创建删除）

# CORS 配置
# 生产环境必须显式配置可信域名列表（逗号分隔），且禁止包含 "*"
# 例如：CORS_ALLOWED_ORIGINS=https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# LLM 配置（核心功能，建议启用）
# 注意：LLM 是 AI Native 特性的核心引擎，禁用后系统将降级为规则引擎模式
LLM_ENABLED=true
LLM_PROVIDER=qwen              # 推荐：qwen（通义千问）/ glm（智谱）/ openai
LLM_API_KEY=                   # 从 https://dashscope.console.aliyun.com/ 获取
LLM_API_BASE=https://dashscope.aliyun.com/compatible-mode/v1
LLM_MODEL=qwen-plus            # 推荐：qwen-plus / qwen-turbo / glm-4
LLM_TEMPERATURE=0.7            # 0.0-1.0，越高越随机
LLM_MAX_TOKENS=1000            # 单次响应最大 token 数
LLM_REQUEST_TIMEOUT=30         # 请求超时时间（秒）
LLM_RETRY_COUNT=3              # 失败重试次数
LLM_CONFIDENCE_THRESHOLD=0.6   # 置信度阈值（低于此值的结果会被过滤）
LLM_DAILY_TOKEN_LIMIT=100000   # 每日 token 使用上限（成本控制）

# 孵化器门户集成（可选）
PORTAL_ENABLED=false
PORTAL_API_URL=
PORTAL_API_KEY=

# ==================== 外部服务配置 ====================
# 说明：以下是外部服务集成配置，生产环境建议启用真实服务以获得完整功能体验

# 高德地图 API 配置（用于地理编码、距离计算、地点搜索）
# 访问 https://lbs.amap.com/ 获取 API Key
# 用于：附近的人、约会地点推荐、地理围栏等
AMAP_API_KEY=your_amap_api_key
AMAP_API_SECRET=your_amap_api_secret  # 可选，用于安全签名
AMAP_ENABLED=false                    # 生产环境建议设置为 true

# 天气服务配置（用于 P14 穿搭推荐、约会建议）
# 服务提供商：mock（模拟数据）, qweather（和风天气，推荐国内）, openweathermap（推荐国际）
WEATHER_PROVIDER=qweather             # 推荐：qweather / openweathermap / mock
QWEATHER_API_KEY=                     # 从 https://dev.qweather.com/ 获取（国内推荐）
OPENWEATHERMAP_API_KEY=               # 从 https://openweathermap.org/api 获取（国际推荐）

# 预订服务配置（用于 P15 自主约会策划）
# 服务提供商：mock（模拟数据）, dianping（大众点评）, maoyan（猫眼电影）
RESERVATION_RESTAURANT_PROVIDER=dianping  # 餐厅预订：dianping / mock
RESERVATION_CINEMA_PROVIDER=maoyan        # 电影预订：maoyan / mock
DIANPING_API_KEY=                         # 从大众点评开放平台获取
DIANPING_API_SECRET=
MAOYAN_API_KEY=                           # 从猫眼开放平台获取

# 极光推送配置（用于移动端推送通知）
# 访问 https://www.jiguang.cn/ 获取 AppKey 和 Master Secret
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret
JPUSH_ENABLED=false                     # 生产环境建议设置为 true

# ==================== 短信服务配置（阿里云） ====================
# 访问 https://dysms.console.aliyun.com/ 配置
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=你的签名名称
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
ALIYUN_SMS_ENABLED=false

# ==================== 支付配置 ====================

# 微信支付配置
WECHAT_PAY_APPID=your_wechat_pay_appid
WECHAT_PAY_MCHID=your_wechat_pay_mchid
WECHAT_PAY_API_V3_KEY=your_wechat_pay_api_v3_key
WECHAT_PAY_SERIAL_NO=your_wechat_pay_serial_no
WECHAT_PAY_ENABLED=false

# 支付宝配置
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_ENABLED=false
