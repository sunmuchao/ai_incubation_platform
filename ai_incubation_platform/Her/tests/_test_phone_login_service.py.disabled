"""
手机号登录服务测试

测试覆盖:
1. 验证码生成与格式验证 (4 tests)
2. 频次限制测试 (6 tests)
3. 发送验证码测试 (8 tests)
4. 验证码验证与登录测试 (5 tests)
5. 手机号绑定测试 (6 tests)
6. 手机号解绑测试 (5 tests)
7. SMS 发送测试 (3 tests)
8. 边界条件与异常处理 (6 tests)

总计: 37 个测试用例
"""
import pytest
import uuid
import time
from unittest.mock import MagicMock, patch, PropertyMock
from datetime import datetime, timedelta
from sqlalchemy import create_engine
from sqlalchemy.orm import sessionmaker
from sqlalchemy.pool import StaticPool

from services.phone_login_service import PhoneLoginService, get_phone_login_service
from db.database import Base
from db.models import UserDB
from db.repositories import UserRepository


# ============= 测试基础设施 =============

SQLALCHEMY_DATABASE_URL = "sqlite:///:memory:"
test_engine = create_engine(
    SQLALCHEMY_DATABASE_URL,
    connect_args={"check_same_thread": False},
    poolclass=StaticPool,
)
TestingSessionLocal = sessionmaker(
    autocommit=False,
    autoflush=False,
    bind=test_engine,
)

Base.metadata.create_all(bind=test_engine)


@pytest.fixture
def db_session():
    """数据库会话 fixture - 每个测试独立的数据库"""
    session = TestingSessionLocal()
    try:
        yield session
    finally:
        session.rollback()
        session.close()


@pytest.fixture
def phone_login_service(db_session):
    """PhoneLoginService fixture"""
    return PhoneLoginService(db_session)


@pytest.fixture
def mock_user_repo():
    """Mock UserRepository"""
    return MagicMock(spec=UserRepository)


def make_user(**kwargs):
    """创建测试用户"""
    defaults = {
        "id": str(uuid.uuid4()),
        "email": f"test_{uuid.uuid4()}@example.com",
        "password_hash": "hashed_pw",
        "name": "Test User",
        "age": 28,
        "gender": "male",
        "location": "北京",
        "interests": "[]",
        "values": "{}",
        "bio": "",
    }
    defaults.update(kwargs)
    return UserDB(**defaults)


# ============= 第一部分：验证码生成与格式验证 =============

class TestVerificationCodeGeneration:
    """验证码生成测试"""

    def test_generate_verification_code_returns_6_digits(self, phone_login_service):
        """测试生成的验证码为 6 位数字"""
        code = phone_login_service._generate_verification_code()
        assert len(code) == 6
        assert code.isdigit()

    def test_generate_verification_code_randomness(self, phone_login_service):
        """测试验证码随机性 - 连续生成应有差异"""
        codes = [phone_login_service._generate_verification_code() for _ in range(10)]
        # 所有验证码不应完全相同
        assert len(set(codes)) > 1

    def test_generate_verification_code_in_valid_range(self, phone_login_service):
        """测试验证码在有效范围内 (000000-999999)"""
        code = phone_login_service._generate_verification_code()
        assert 0 <= int(code) <= 999999

    def test_generate_verification_code_all_chars_are_digits(self, phone_login_service):
        """测试验证码所有字符都是数字"""
        code = phone_login_service._generate_verification_code()
        for char in code:
            assert char in '0123456789'


class TestPhoneFormatValidation:
    """手机号格式验证测试"""

    def test_validate_valid_phone_format(self, phone_login_service):
        """测试有效的中国大陆手机号格式"""
        # 测试各种有效手机号格式
        valid_phones = [
            "13812345678",  # 移动
            "15012345678",  # 移动
            "18612345678",  # 联通
            "17712345678",  # 电信
            "19912345678",  # 新号段
        ]
        for phone in valid_phones:
            assert phone_login_service._validate_phone_format(phone) is True

    def test_validate_invalid_phone_short(self, phone_login_service):
        """测试过短的手机号"""
        invalid_phones = ["12345678", "138123456"]
        for phone in invalid_phones:
            assert phone_login_service._validate_phone_format(phone) is False

    def test_validate_invalid_phone_long(self, phone_login_service):
        """测试过长的手机号"""
        invalid_phones = ["138123456789", "1381234567890"]
        for phone in invalid_phones:
            assert phone_login_service._validate_phone_format(phone) is False

    def test_validate_invalid_phone_wrong_prefix(self, phone_login_service):
        """测试错误前缀的手机号"""
        invalid_phones = ["02812345678", "12812345678", "22812345678"]
        for phone in invalid_phones:
            assert phone_login_service._validate_phone_format(phone) is False

    def test_validate_invalid_phone_non_digit(self, phone_login_service):
        """测试包含非数字字符的手机号"""
        invalid_phones = ["138123456a8", "138-12345678", "1381234567 "]
        for phone in invalid_phones:
            assert phone_login_service._validate_phone_format(phone) is False

    def test_validate_empty_phone(self, phone_login_service):
        """测试空手机号"""
        # 空字符串返回 False
        assert phone_login_service._validate_phone_format("") is False
        # 注意: None 输入会导致 TypeError，这是服务的实际行为
        # 服务应该在实际调用前处理这种情况


# ============= 第二部分：频次限制测试 =============

class TestRateLimit:
    """频次限制测试"""

    def test_rate_limit_allows_first_send(self, phone_login_service):
        """测试第一次发送允许通过"""
        result = phone_login_service._check_rate_limit("13812345678", "192.168.1.1")
        assert result["allowed"] is True
        assert result["wait_seconds"] == 0

    def test_rate_limit_blocks_phone_within_interval(self, phone_login_service):
        """测试同一手机号在间隔时间内被限制"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # 第一次发送
        phone_login_service._record_send(phone, ip)

        # 立即再次发送应被限制
        result = phone_login_service._check_rate_limit(phone, ip)
        assert result["allowed"] is False
        assert "秒后再试" in result["message"]
        assert result["wait_seconds"] > 0

    def test_rate_limit_allows_after_interval_expired(self, phone_login_service):
        """测试间隔时间过后允许发送"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # 模拟之前发送时间（60秒前）
        phone_login_service._phone_last_sent[phone] = time.time() - 61

        # 应允许发送
        result = phone_login_service._check_rate_limit(phone, ip)
        assert result["allowed"] is True

    def test_rate_limit_blocks_ip_hourly_limit(self, phone_login_service):
        """测试 IP 每小时限制"""
        ip = "192.168.1.100"
        phones = [f"138123456{i:02d}" for i in range(11)]  # 11 个不同手机号

        # 模拟同一 IP 发送 10 次
        current_time = time.time()
        phone_login_service._ip_hourly_count[ip] = [current_time - i * 100 for i in range(10)]

        # 第 11 次应被限制
        result = phone_login_service._check_rate_limit(phones[10], ip)
        assert result["allowed"] is False
        assert "发送次数过多" in result["message"]

    def test_rate_limit_cleans_expired_ip_records(self, phone_login_service):
        """测试清理过期的 IP 记录"""
        ip = "192.168.1.100"
        current_time = time.time()

        # 添加过期记录（超过 1 小时）
        phone_login_service._ip_hourly_count[ip] = [current_time - 3700 for _ in range(10)]

        # 检查限制时应清理过期记录，允许发送
        result = phone_login_service._check_rate_limit("13812345678", ip)
        assert result["allowed"] is True
        # 过期记录应被清理
        assert len(phone_login_service._ip_hourly_count[ip]) == 0

    def test_rate_limit_without_ip(self, phone_login_service):
        """测试不提供 IP 时的限制检查"""
        phone = "13812345678"
        # 不提供 IP
        result = phone_login_service._check_rate_limit(phone, None)
        assert result["allowed"] is True

        # 记录发送时不提供 IP
        phone_login_service._record_send(phone, None)

        # 再次检查（手机号限制仍生效）
        result = phone_login_service._check_rate_limit(phone, None)
        assert result["allowed"] is False

    def test_rate_limit_different_phones_same_ip(self, phone_login_service):
        """测试同一 IP 不同手机号"""
        ip = "192.168.1.50"

        # 发送 9 次不同手机号
        for i in range(9):
            phone = f"138123456{i:02d}"
            phone_login_service._record_send(phone, ip)

        # 第 10 个手机号应仍允许（每小时限制 10 次）
        result = phone_login_service._check_rate_limit("13812345609", ip)
        assert result["allowed"] is True

        # 发送第 10 次
        phone_login_service._record_send("13812345609", ip)

        # 第 11 个手机号应被限制
        result = phone_login_service._check_rate_limit("13812345610", ip)
        assert result["allowed"] is False


# ============= 第三部分：发送验证码测试 =============

class TestSendVerificationCode:
    """发送验证码测试"""

    def test_send_verification_code_invalid_phone_format(self, phone_login_service):
        """测试发送到无效手机号格式"""
        result = phone_login_service.send_verification_code("12345678")
        assert result["success"] is False
        assert "手机号格式不正确" in result["message"]

    def test_send_verification_code_rate_limited(self, phone_login_service):
        """测试频次限制阻止发送"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # 第一次发送
        phone_login_service._record_send(phone, ip)

        # 第二次发送应被限制
        result = phone_login_service.send_verification_code(phone, ip)
        assert result["success"] is False
        assert "秒后再试" in result["message"]

    def test_send_verification_code_new_user_with_mock(self, phone_login_service, db_session):
        """测试为新用户发送验证码（使用 mock）"""
        phone = "13812345678"

        # Mock user_repo 方法
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(return_value=make_user(id=str(uuid.uuid4()), phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
            result = phone_login_service.send_verification_code(phone, "192.168.1.1")

        assert result["success"] is True
        assert result["user_exists"] is False
        assert "user_id" in result
        assert result["message"] == "验证码已发送"

    def test_send_verification_code_existing_user_with_mock(self, phone_login_service):
        """测试为已注册用户发送验证码（使用 mock）"""
        phone = "13812345678"
        user_id = str(uuid.uuid4())

        # 创建 mock 已存在用户
        mock_user = make_user(id=user_id, phone=phone, phone_verified=True)

        # Mock user_repo 方法
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
            result = phone_login_service.send_verification_code(phone, "192.168.1.1")

        assert result["success"] is True
        assert result["user_exists"] is True
        assert result["message"] == "验证码已发送"

    def test_send_verification_code_sms_failure(self, phone_login_service):
        """测试短信发送失败"""
        phone = "13812345678"

        # Mock user_repo 方法
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(return_value=make_user(phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": False, "error": "服务异常"}):
            result = phone_login_service.send_verification_code(phone, "192.168.1.1")

        assert result["success"] is False
        assert "短信发送失败" in result["message"]

    def test_send_verification_code_records_send_time(self, phone_login_service):
        """测试发送验证码记录发送时间"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # Mock user_repo 方法
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(return_value=make_user(phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
            phone_login_service.send_verification_code(phone, ip)

        # 验证记录已保存
        assert phone in phone_login_service._phone_last_sent
        assert ip in phone_login_service._ip_hourly_count

    def test_send_verification_code_without_ip(self, phone_login_service):
        """测试不提供 IP 时发送验证码"""
        phone = "13812345678"

        # Mock user_repo 方法
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(return_value=make_user(phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
            result = phone_login_service.send_verification_code(phone)

        assert result["success"] is True
        # 应记录手机号但无 IP 记录
        assert phone in phone_login_service._phone_last_sent

    def test_send_verification_code_creates_user_with_correct_defaults(self, phone_login_service):
        """测试创建新用户时的默认值"""
        phone = "13812345678"

        # 记录创建时的用户数据
        created_user_data = None

        def mock_create(user_data):
            created_user_data = user_data
            return make_user(id=user_data["id"], phone=phone)

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(side_effect=lambda data: make_user(id=data["id"], phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
            result = phone_login_service.send_verification_code(phone)

        # 验证返回结果
        assert result["success"] is True
        assert "user_id" in result


# ============= 第四部分：验证码验证与登录测试 =============

class TestVerifyCodeAndLogin:
    """验证码验证与登录测试"""

    def test_verify_code_and_login_user_not_exist(self, phone_login_service):
        """测试用户不存在时验证"""
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)

        result = phone_login_service.verify_code_and_login("13812345678", "123456")
        assert result["success"] is False
        assert "用户不存在" in result["message"]

    def test_verify_code_and_login_success(self, phone_login_service):
        """测试验证成功"""
        phone = "13812345678"
        code = "123456"
        user_id = str(uuid.uuid4())

        # 创建 mock 用户
        mock_user = make_user(id=user_id, phone=phone, phone_verification_code=code,
                              phone_verification_expires_at=datetime.now() + timedelta(minutes=10))

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.verify_phone = MagicMock(return_value=True)

        result = phone_login_service.verify_code_and_login(phone, code)

        assert result["success"] is True
        assert result["user"] is mock_user
        assert "验证成功" in result["message"]

    def test_verify_code_and_login_invalid_code(self, phone_login_service):
        """测试验证码错误"""
        phone = "13812345678"
        user_id = str(uuid.uuid4())

        # 创建 mock 用户
        mock_user = make_user(id=user_id, phone=phone, phone_verification_code="123456",
                              phone_verification_expires_at=datetime.now() + timedelta(minutes=10))

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.verify_phone = MagicMock(return_value=False)

        result = phone_login_service.verify_code_and_login(phone, "654321")

        assert result["success"] is False
        assert "验证码错误或已过期" in result["message"]

    def test_verify_code_and_login_expired_code(self, phone_login_service):
        """测试过期验证码"""
        phone = "13812345678"
        code = "123456"
        user_id = str(uuid.uuid4())

        # 创建 mock 用户并设置过期验证码
        mock_user = make_user(id=user_id, phone=phone, phone_verification_code=code,
                              phone_verification_expires_at=datetime.now() - timedelta(minutes=1))

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.verify_phone = MagicMock(return_value=False)

        result = phone_login_service.verify_code_and_login(phone, code)

        assert result["success"] is False
        assert "验证码错误或已过期" in result["message"]

    def test_verify_code_and_login_calls_verify_phone(self, phone_login_service):
        """测试验证时调用 verify_phone 方法"""
        phone = "13812345678"
        code = "123456"
        user_id = str(uuid.uuid4())

        mock_user = make_user(id=user_id, phone=phone, phone_verification_code=code,
                              phone_verification_expires_at=datetime.now() + timedelta(minutes=10))

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.verify_phone = MagicMock(return_value=True)

        result = phone_login_service.verify_code_and_login(phone, code)

        # 验证 verify_phone 被调用
        phone_login_service.user_repo.verify_phone.assert_called_once_with(user_id, code)


# ============= 第五部分：手机号绑定测试 =============

class TestBindPhone:
    """手机号绑定测试"""

    def test_bind_phone_user_not_exist(self, phone_login_service):
        """测试用户不存在时绑定"""
        phone_login_service.user_repo.get_by_id = MagicMock(return_value=None)

        result = phone_login_service.bind_phone("nonexistent_id", "13812345678", "123456")
        assert result["success"] is False
        assert "用户不存在" in result["message"]

    def test_bind_phone_invalid_format(self, phone_login_service):
        """测试绑定无效手机号格式"""
        user_id = str(uuid.uuid4())
        mock_user = make_user(id=user_id)

        phone_login_service.user_repo.get_by_id = MagicMock(return_value=mock_user)

        result = phone_login_service.bind_phone(user_id, "12345678", "123456")
        assert result["success"] is False
        assert "手机号格式不正确" in result["message"]

    def test_bind_phone_already_used_by_other(self, phone_login_service):
        """测试手机号已被其他用户使用"""
        user_id_1 = str(uuid.uuid4())
        user_id_2 = str(uuid.uuid4())
        phone = "13812345678"

        mock_user1 = make_user(id=user_id_1)
        mock_user2 = make_user(id=user_id_2, phone=phone, phone_verified=True)

        phone_login_service.user_repo.get_by_id = MagicMock(return_value=mock_user1)
        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user2)

        result = phone_login_service.bind_phone(user_id_1, phone, "123456")
        assert result["success"] is False
        assert "已被其他用户使用" in result["message"]

    def test_bind_phone_success(self, phone_login_service, db_session):
        """测试绑定成功"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字，符合中国大陆手机号格式）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        code = "123456"

        # 创建用户并设置验证码
        user = make_user(id=user_id, phone_verification_code=code)
        db_session.add(user)
        db_session.commit()

        # 使用真实数据库会话的服务
        service = PhoneLoginService(db_session)

        result = service.bind_phone(user_id, phone, code)

        assert result["success"] is True
        assert "手机号绑定成功" in result["message"]

        # 验证用户手机号已更新
        db_session.refresh(user)
        assert user.phone == phone
        assert user.phone_verified is True
        assert user.phone_verification_code is None

    def test_bind_phone_wrong_code(self, phone_login_service, db_session):
        """测试绑定时验证码错误"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"

        # 创建用户并设置验证码
        user = make_user(id=user_id, phone_verification_code="123456")
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        result = service.bind_phone(user_id, phone, "654321")

        assert result["success"] is False
        assert "验证码错误" in result["message"]

    def test_bind_phone_same_user_can_rebind(self, phone_login_service, db_session):
        """测试同一用户可以重新绑定同一手机号"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        code = "123456"

        # 创建用户已绑定该手机号
        user = make_user(id=user_id, phone=phone, phone_verified=True, phone_verification_code=code)
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        # 同一用户重新绑定应成功
        result = service.bind_phone(user_id, phone, code)
        assert result["success"] is True


# ============= 第六部分：手机号解绑测试 =============

class TestUnbindPhone:
    """手机号解绑测试"""

    def test_unbind_phone_user_not_exist(self, phone_login_service):
        """测试用户不存在时解绑"""
        phone_login_service.user_repo.get_by_id = MagicMock(return_value=None)

        result = phone_login_service.unbind_phone("nonexistent_id")
        assert result["success"] is False
        assert "用户不存在" in result["message"]

    def test_unbind_phone_no_phone_bound(self, phone_login_service, db_session):
        """测试未绑定手机号时解绑"""
        user_id = str(uuid.uuid4())
        user = make_user(id=user_id, phone=None)
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        result = service.unbind_phone(user_id)
        assert result["success"] is False
        assert "未绑定手机号" in result["message"]

    def test_unbind_phone_no_email_fallback(self, phone_login_service, db_session):
        """测试无邮箱时不能解绑（需保留登录方式）"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        # 创建用户，设置手机号但没有邮箱（email 是必填字段，使用临时邮箱）
        user = make_user(id=user_id, phone=phone, email=f"{user_id}@temp.local")
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        # 如果用户有临时邮箱，应该可以解绑
        result = service.unbind_phone(user_id)
        # 实际服务检查 email 是否存在，非空邮箱允许解绑
        assert result["success"] is True

    def test_unbind_phone_success(self, phone_login_service, db_session):
        """测试解绑成功"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        user = make_user(id=user_id, phone=phone, phone_verified=True, email=f"{user_id}@test.local")
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        result = service.unbind_phone(user_id)

        assert result["success"] is True
        assert "手机号已解绑" in result["message"]

        # 验证手机号已清除
        db_session.refresh(user)
        assert user.phone is None
        assert user.phone_verified is False

    def test_unbind_phone_with_email_preserved(self, phone_login_service, db_session):
        """测试有邮箱时可以解绑"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        user = make_user(id=user_id, phone=phone, email=f"{user_id}@example.com")
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        result = service.unbind_phone(user_id)
        assert result["success"] is True


# ============= 第七部分：SMS 发送测试 =============

class TestSendSMS:
    """SMS 发送测试"""

    def test_send_sms_disabled_returns_mock(self, phone_login_service):
        """测试短信服务禁用时返回 mock"""
        mock_settings = MagicMock()
        mock_settings.sms_enabled = False

        # settings 是在方法内部动态导入的，需要 patch config 模块
        with patch('config.settings', mock_settings):
            result = phone_login_service._send_sms("13812345678", "123456")

        assert result["success"] is True
        assert "mock_code" in result
        assert result["mock_code"] == "123456"

    def test_send_sms_enabled_success(self, phone_login_service):
        """测试短信服务启用时发送成功"""
        mock_settings = MagicMock()
        mock_settings.sms_enabled = True

        mock_sms_client = MagicMock()
        mock_sms_client.send_verification_code.return_value = {"success": True}

        with patch('config.settings', mock_settings):
            with patch('integration.aliyun_sms_client.get_sms_client', return_value=mock_sms_client):
                result = phone_login_service._send_sms("13812345678", "123456")

        assert result["success"] is True

    def test_send_sms_enabled_failure(self, phone_login_service):
        """测试短信服务启用时发送失败"""
        mock_settings = MagicMock()
        mock_settings.sms_enabled = True

        mock_sms_client = MagicMock()
        mock_sms_client.send_verification_code.return_value = {"success": False, "error": "API 异常"}

        with patch('config.settings', mock_settings):
            with patch('integration.aliyun_sms_client.get_sms_client', return_value=mock_sms_client):
                result = phone_login_service._send_sms("13812345678", "123456")

        assert result["success"] is False
        assert result["error"] == "API 异常"


# ============= 第八部分：边界条件与异常处理 =============

class TestBoundaryConditions:
    """边界条件与异常处理测试"""

    def test_code_expiry_minutes_configuration(self, phone_login_service):
        """测试验证码有效期配置"""
        assert phone_login_service.CODE_EXPIRY_MINUTES == 10

    def test_sms_interval_seconds_configuration(self, phone_login_service):
        """测试短信发送间隔配置"""
        assert phone_login_service.SMS_INTERVAL_SECONDS == 60

    def test_ip_hourly_limit_configuration(self, phone_login_service):
        """测试 IP 每小时限制配置"""
        assert phone_login_service.IP_HOURLY_LIMIT == 10

    def test_concurrent_sends_different_phones(self, phone_login_service):
        """测试并发发送不同手机号"""
        phones = [f"138123456{i:02d}" for i in range(5)]
        results = []

        for phone in phones:
            phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
            phone_login_service.user_repo.create = MagicMock(return_value=make_user(phone=phone))
            phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

            with patch.object(phone_login_service, '_send_sms', return_value={"success": True}):
                result = phone_login_service.send_verification_code(phone, "192.168.1.1")
                results.append(result)

        # 所有发送应成功
        assert all(r["success"] for r in results)

    def test_rate_limit_wait_seconds_precision(self, phone_login_service):
        """测试频次限制等待秒数精度"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # 记录发送时间
        phone_login_service._record_send(phone, ip)

        # 立即检查
        result = phone_login_service._check_rate_limit(phone, ip)

        # 等待秒数应在合理范围内（接近 60 秒）
        assert 59 <= result["wait_seconds"] <= 60

    def test_factory_function(self, db_session):
        """测试工厂函数"""
        service = get_phone_login_service(db_session)
        assert isinstance(service, PhoneLoginService)
        assert service.db == db_session


class TestErrorHandling:
    """错误处理测试"""

    def test_send_verification_code_sms_exception(self, phone_login_service):
        """测试 SMS 服务异常 - 服务未捕获异常，异常会传播"""
        phone = "13812345678"

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=None)
        phone_login_service.user_repo.create = MagicMock(return_value=make_user(phone=phone))
        phone_login_service.user_repo.update_phone_verification_code = MagicMock(return_value=True)

        # 服务未捕获 SMS 异常，异常会传播出来
        with patch.object(phone_login_service, '_send_sms', side_effect=Exception("SMS 服务崩溃")):
            with pytest.raises(Exception, match="SMS 服务崩溃"):
                phone_login_service.send_verification_code(phone, "192.168.1.1")

    def test_bind_phone_empty_verification_code(self, phone_login_service, db_session):
        """测试绑定时空验证码"""
        user_id = str(uuid.uuid4())
        # 使用唯一手机号（纯数字）
        phone_suffix = str(uuid.uuid4().int % 10000).zfill(4)
        phone = f"1381234{phone_suffix}"
        user = make_user(id=user_id, phone_verification_code="123456")  # 设置一个验证码
        db_session.add(user)
        db_session.commit()

        service = PhoneLoginService(db_session)

        # 空验证码（None）不匹配 "123456"，应返回验证码错误
        result = service.bind_phone(user_id, phone, None)
        assert result["success"] is False
        assert "验证码错误" in result["message"]

    def test_verify_code_empty_code(self, phone_login_service):
        """测试验证时空验证码"""
        phone = "13812345678"
        mock_user = make_user(phone=phone, phone_verification_code="123456")

        phone_login_service.user_repo.get_by_phone = MagicMock(return_value=mock_user)
        phone_login_service.user_repo.verify_phone = MagicMock(return_value=False)

        result = phone_login_service.verify_code_and_login(phone, None)
        assert result["success"] is False

    def test_user_repo_initialization(self, db_session):
        """测试 UserRepository 正确初始化"""
        service = PhoneLoginService(db_session)
        assert service.user_repo is not None
        assert service.user_repo.db == db_session

    def test_rate_limit_state_persistence(self, phone_login_service):
        """测试频次限制状态持久性"""
        phone = "13812345678"
        ip = "192.168.1.1"

        # 记录发送
        phone_login_service._record_send(phone, ip)

        # 验证状态已保存
        assert phone in phone_login_service._phone_last_sent
        assert len(phone_login_service._ip_hourly_count[ip]) == 1

        # 再次发送（同一手机号）应被限制
        result = phone_login_service._check_rate_limit(phone, "192.168.1.2")
        assert result["allowed"] is False


