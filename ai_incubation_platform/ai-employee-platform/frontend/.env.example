# API Configuration
VITE_API_BASE_URL=http://localhost:8003
VITE_WS_URL=ws://localhost:8003

# App Configuration
VITE_APP_TITLE=AI Employee Platform
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_MOCK=false
VITE_ENABLE_DEVTOOLS=true

# Authentication
VITE_TOKEN_KEY=ai_employee_token
VITE_REFRESH_TOKEN_KEY=ai_employee_refresh_token

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_PAGE_SIZE_OPTIONS=10,20,50,100
