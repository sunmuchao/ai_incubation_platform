# AI 员工出租平台 - 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值

# ==================== 应用基础配置 ====================
ENVIRONMENT=development
# 运行环境：development/staging/production

APP_NAME=AI Employee Platform
APP_VERSION=0.7.0
DEBUG=true

# ==================== 安全配置 (必须修改) ====================
# JWT 密钥：必须设置，长度 >= 32，生产环境请使用强随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 加密密钥：用于敏感数据加密
# 生成方法：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# CORS 配置：生产环境必须限制为实际域名
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 数据库配置 ====================
# SQLite (开发环境)
DATABASE_URL=sqlite:///./ai_employee_platform.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_employee_platform

# ==================== Redis 配置 (可选) ====================
REDIS_URL=redis://localhost:6379/0

# ==================== 支付宝配置 ====================
# 沙箱环境
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://your-domain.com/api/payment/callback/alipay

# 生产环境 (取消注释并填入实际配置)
# ALIPAY_APP_ID=your-production-app-id
# ALIPAY_PRIVATE_KEY=your-production-private-key
# ALIPAY_PUBLIC_KEY=your-production-public-key
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/callback/alipay

# ==================== 微信支付配置 ====================
# 沙箱环境
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_SERIAL_NUMBER=
WECHAT_PAY_NOTIFY_URL=http://your-domain.com/api/payment/callback/wechat

# 生产环境 (取消注释并填入实际配置)
# WECHAT_PAY_MCH_ID=your-production-mch-id
# WECHAT_PAY_APP_ID=your-production-app-id
# WECHAT_PAY_API_V3_KEY=your-production-api-v3-key
# WECHAT_PAY_PRIVATE_KEY=your-production-private-key
# WECHAT_PAY_SERIAL_NUMBER=your-production-serial-number
# WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/callback/wechat

# ==================== Stripe 配置 (国际支付) ====================
# 测试环境
STRIPE_API_KEY=sk_test_your-stripe-api-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_NOTIFY_URL=http://your-domain.com/api/payment/callback/stripe

# 生产环境 (取消注释并填入实际配置)
# STRIPE_API_KEY=sk_live_your-stripe-api-key
# STRIPE_WEBHOOK_SECRET=whsec_your-production-webhook-secret
# STRIPE_NOTIFY_URL=https://your-domain.com/api/payment/callback/stripe

# ==================== 邮件通知配置 (SendGrid) ====================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# ==================== 短信通知配置 (阿里云) ====================
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=你的签名
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ==================== DeerFlow 配置 ====================
DEERFLOW_GATEWAY_URL=

# ==================== 文件存储配置 ====================
# 本地存储 (开发环境)
FILE_STORAGE_PATH=./uploads

# S3 存储 (生产环境)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
