# AI Traffic Booster 环境配置示例
# 复制此文件为 .env、.env.development、.env.staging 或 .env.production

# ==================== 基础配置 ====================
APP_NAME=AI Traffic Booster
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8008
WORKERS=1

# ==================== 数据库配置 ====================
# SQLite (开发/测试)
DATABASE_URL=sqlite:///./ai_traffic_booster.db

# PostgreSQL (生产)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_traffic_booster

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (可选，用于缓存)
# REDIS_URL=redis://localhost:6379/0

# ==================== 安全配置 ====================
# 生产环境必须设置，至少 32 字符
SECRET_KEY=your-super-secret-key-here-change-in-production-must-be-32-chars

ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["*"]

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
# LOG_FILE=ai_traffic_booster.log
LOG_FORMAT=text

# ==================== OpenAI 配置 ====================
# OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# ==================== Anthropic Claude API 配置 (P7) ====================
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ==================== IP 地理位置配置 (P7) ====================
# GEOIP_DB_PATH=data/geoip
# IPAPI_KEY=your-ipapi-key (可选，用于在线 IP 查询)

# ==================== Google API 配置 ====================
# GOOGLE_SEARCH_API_KEY=your-google-search-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/credentials.json
# GOOGLE_SEARCH_CONSOLE_SITE_URL=https://your-site.com
# GOOGLE_ADS_CREDENTIALS_PATH=/path/to/ads-credentials.json
# GOOGLE_ADS_CUSTOMER_ID=your-customer-id
# GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# ==================== Ahrefs API 配置 ====================
# AHREFS_API_KEY=your-ahrefs-api-key

# ==================== SEMrush API 配置 ====================
# SEMRUSH_API_KEY=your-semrush-api-key

# ==================== SEO 配置 ====================
MIN_CONTENT_LENGTH=300
MAX_CONTENT_LENGTH=10000
MIN_KEYWORD_DENSITY=1.0
MAX_KEYWORD_DENSITY=5.0
OPTIMAL_KEYWORD_DENSITY_MIN=1.0
OPTIMAL_KEYWORD_DENSITY_MAX=3.0

# ==================== A/B 测试配置 ====================
DEFAULT_CONFIDENCE_LEVEL=0.95
DEFAULT_MIN_SAMPLE_SIZE=1000

# ==================== 数据源配置 ====================
DEFAULT_KEYWORD_SOURCE=mock
DEFAULT_COMPETITOR_SOURCE=mock

# ==================== 限流配置 ====================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==================== 缓存配置 ====================
CACHE_ENABLED=false
CACHE_TTL=3600

# ==================== 监控配置 ====================
# SENTRY_DSN=https://your-sentry-dsn
METRICS_ENABLED=false
