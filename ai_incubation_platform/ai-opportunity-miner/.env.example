# 服务配置
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8006
DEBUG=True

# ============= P5 真实数据源配置 =============

# 新闻 API 配置（P5 已实现 - NewsAPI）
# 免费计划：100 次/天，适合开发和测试
# 注册地址：https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key
NEWS_API_URL=https://newsapi.org/v2/everything

# 企业数据 API 配置（P5 已实现 - OpenCorporates）
# 免费计划：非商业用途免费，需注明数据来源
# 注册地址：https://opencorporates.com/accounts/sign_up
# API URL 可不配置，默认使用 OpenCorporates
ENTERPRISE_API_KEY=your_opencorporates_token
# ENTERPRISE_API_URL=https://api.opencorporates.com/v0.4/companies/search

# ============= 可选数据源配置 =============

# 行业报告 API 配置（可选）
# INDUSTRY_REPORT_API_URL=https://api.example.com/reports
# INDUSTRY_REPORT_API_KEY=your_report_api_key

# 融资事件 API 配置（P5 预留 - IT 桔子/鲸准）
# IT 桔子：需要商务合作获取 API
# 鲸准：https://www.jingdata.com/
# FINANCING_API_KEY=your_financing_api_key
# FINANCING_API_URL=https://api.itjuzi.com/api/v1/companies

# 专利数据 API 配置（P5 预留 - 国家知识产权局）
# 国家知识产权局：https://www.cnipa.gov.cn/
# PATENT_API_KEY=your_patent_api_key
# PATENT_API_URL=https://api.cnipa.gov.cn/patent/search

# 社交媒体 API 配置（P5 预留 - 微博/Twitter）
# WEIBO_API_KEY=your_weibo_app_key
# WEIBO_API_URL=https://api.weibo.com/2/search/statuses
# TWITTER_API_KEY=your_twitter_api_key
# TWITTER_API_URL=https://api.twitter.com/2/tweets/search/recent

# ============= 其他配置 =============

# LLM 配置（可选，使用 OpenAI/文心一言/通义千问等）
# LLM_API_KEY=your_llm_api_key
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-3.5-turbo

# 数据存储配置
DATA_DIR=./data
EXPORT_DIR=./exports

# 数据库配置（可选，默认使用 SQLite）
# DATABASE_URL=sqlite:///./data/opportunity_miner.db
# DATABASE_URL=postgresql://user:password@localhost:5432/opportunity_db

# DeerFlow 配置（可选）
# DEERFLOW_GATEWAY_URL=http://localhost:2026
# DEERFLOW_CONFIG_PATH=/path/to/deerflow/config.yaml
