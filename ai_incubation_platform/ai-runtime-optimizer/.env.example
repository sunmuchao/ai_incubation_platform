# AI 运行态优化器配置示例
# 复制为 .env 文件并根据实际情况修改

# ==================== 服务配置 ====================
AI_OPTIMIZER_HOST=0.0.0.0
AI_OPTIMIZER_PORT=8012
AI_OPTIMIZER_DEBUG=false

# ==================== 策略引擎配置 ====================
AI_OPTIMIZER_BUILTIN_STRATEGIES=true
# AI_OPTIMIZER_STRATEGIES_DIR=./custom_strategies

# ==================== LLM 配置 ====================
# 启用 LLM 增强（可选）
AI_OPTIMIZER_LLM_ENABLED=false

# LLM 提供商选择：mock, openai, claude
AI_OPTIMIZER_LLM_PROVIDER=mock

# OpenAI 配置（当 provider=openai 时）
# AI_OPTIMIZER_LLM_API_KEY=sk-your-openai-api-key
# AI_OPTIMIZER_LLM_MODEL=gpt-4

# Claude 配置（当 provider=claude 时）
# AI_OPTIMIZER_LLM_API_KEY=your-anthropic-api-key
# AI_OPTIMIZER_LLM_MODEL=claude-sonnet-4-20250514

# ==================== 存储配置 ====================
# 存储类型：memory, redis
AI_OPTIMIZER_STORAGE=memory

# Redis 配置（当 storage_type=redis 时）
# AI_OPTIMIZER_REDIS_URL=redis://localhost:6379/0
AI_OPTIMIZER_STORAGE_MAX_RECORDS=100

# ==================== 安全配置 ====================
AI_OPTIMIZER_AUTO_MERGE=false
AI_OPTIMIZER_REQUIRE_REVIEW=true
AI_OPTIMIZER_REQUIRE_CI=true

# ==================== 生产模式配置 ====================
AI_OPTIMIZER_PRODUCTION_INSIGHT=false
AI_OPTIMIZER_ALLOW_DATA_MODIFICATION=true
AI_OPTIMIZER_ENABLE_INTEGRATIONS=true
